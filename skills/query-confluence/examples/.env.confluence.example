# Confluence API Credentials
#
# This is the MAIN configuration template for the query-confluence skill.
# Copy this file to one of (in order of precedence):
#   .env
#   .env.confluence
#   .env.jira
#   .env.atlassian
#
# Scripts will search for credentials in this order.
# Then fill in your actual credentials.

# Confluence instance URL (Cloud or Server/Data Center)
# Cloud: https://your-domain.atlassian.net
# Server: https://confluence.your-company.com
CONFLUENCE_URL=https://your-domain.atlassian.net

# Username (email for Cloud, username for Server/Data Center)
CONFLUENCE_USERNAME=your.email@example.com

# API Token (Cloud) or Password (Server/Data Center)
# How to get Cloud API token:
# 1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Click "Create API token"
# 3. Give it a name (e.g., "Confluence Downloader")
# 4. Copy the token and paste it below
CONFLUENCE_API_TOKEN=your_api_token_here

# Optional: Default output directory for downloads (default: ./confluence_docs)
# CONFLUENCE_OUTPUT_DIR=confluence_docs

# ----- SECURITY NOTICE -----
# Keep this file secure and do NOT commit it to version control!
# Add these patterns to your .gitignore:
#   .env
#   .env.confluence
#   .env.jira
#   .env.atlassian
#   .env.local
#   .env.*.local
